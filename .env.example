# Copy this file to .env.local and fill in the values.

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Local development (Docker) ──────────────────────────────────────────────
# Start the container: docker compose -f local-db/docker-compose.postgres.yml up -d
# Then run migrations:  npm run db:migrate
DATABASE_URL="postgresql://admin:admin@localhost:5431/smartlock_local"
DATABASE_DIRECT_URL="postgresql://admin:admin@localhost:5431/smartlock_local"

# ── Production (Supabase + Vercel) ──────────────────────────────────────────
# DATABASE_URL  → Supabase connection POOLER — used at runtime by PrismaClient
# DIRECT_URL    → Supabase DIRECT connection — used by prisma migrate only
#
# In Prisma 7 the connection URL for migrations comes from prisma.config.ts (DIRECT_URL).
# The runtime adapter in lib/db.ts uses DATABASE_URL (the pooler).
#
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@db.[ref].supabase.com:5432/postgres"